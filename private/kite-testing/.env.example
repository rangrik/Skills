# Copy to .env (gitignored). The harness loads it automatically.

# The Kite environment to test against — a PR's local dev URL
# (e.g. https://<branch>.kite.localhost from `task print-dev-url`),
# a deploy preview (https://v2dp<PR>.dp.appsmith.com/), staging, or prod.
# Defaults to https://v2.local.com/ if unset.
KITE_BASE_URL=https://v2.local.com/

# Required — powers the agentic act/extract steps.
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-20250514.
LLM_MODEL=

# Optional — override the default shared test account for the `user` role.
SCENARIO_USER_EMAIL=
SCENARIO_USER_PASSWORD=
