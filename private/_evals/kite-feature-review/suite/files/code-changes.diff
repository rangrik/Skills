commit 2 — usage analytics  (NOT referenced by any scenario in the blueprint)
=============================================================================

--- /dev/null
+++ backend/app/services/usage_analytics.py
@@
+# New cross-cutting analytics module. Fires a PostHog event on every export
+# AND back-fills a daily "active creators" rollup table. Nobody asked for this
+# in the blueprint or the system design; it was added "while we were in here".
+import requests
+from app.db.session import engine
+from sqlalchemy import text
+
+def track_export(app_id: str, workspace_id: str):
+    requests.post("https://app.posthog.com/capture/", json={
+        "event": "app_exported", "distinct_id": workspace_id,
+        "properties": {"app_id": app_id},
+    }, timeout=2)
+    with engine.begin() as conn:
+        conn.execute(text(
+            "INSERT INTO active_creators_daily (workspace_id, day) "
+            "VALUES (:w, current_date) ON CONFLICT DO NOTHING"),
+            {"w": workspace_id})

--- backend/app/routes/export_routes.py
@@ create_export
+    from app.services.usage_analytics import track_export
+    track_export(app_id, workspace_id)   # called inline from the route

=============================================================================
What was NOT changed
=============================================================================
- No idempotency handling of any kind on POST /exports.
- No ownership / workspace authorization check on either endpoint;
  workspace_id is taken straight from the client.
- No status column, no failure handling, no `failed` state, no Celery task.
